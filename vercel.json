{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/.well-known/assetlinks.json",
      "destination": "/.well-known/assetlinks.json"
    },
    { "source": "/post/:id", "destination": "/api/preview?type=post&id=:id" },
    { "source": "/u/:username", "destination": "/api/preview?type=u&id=:username" },
    { "source": "/reel/:id", "destination": "/api/preview?type=reel&id=:id" },
    { "source": "/api/preview", "destination": "/api/preview" },
    { "source": "/api/notifications/send", "destination": "/api/notifications/send" },
    { "source": "/api/fetch-preview", "destination": "/api/fetch-preview" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*).(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
