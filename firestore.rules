rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "mdgsty424@gmail.com" && request.auth.token.email_verified == true));
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    function isValidStringLength(field, min, max) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= min && 
             request.resource.data[field].size() <= max;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 && data.uid.size() < 128 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             (!('bio' in data) || (data.bio is string && data.bio.size() < 500)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 1000)) &&
             (!('sex' in data) || (data.sex is string && data.sex.size() < 20)) &&
             (!('birthYear' in data) || (data.birthYear is number && data.birthYear > 1900 && data.birthYear < 2100)) &&
             (!('verified' in data) || data.verified is bool) &&
             (!('onesignalIds' in data) || (data.onesignalIds is list)) &&
             (!('securityOTP' in data) || (data.securityOTP is string || data.securityOTP == null)) &&
             (!('lastSuspiciousIp' in data) || (data.lastSuspiciousIp is string)) &&
             (!('lastNotificationLink' in data) || (data.lastNotificationLink is timestamp));
    }
    function isValidIdentity(data) {
      return (!('nameBangla' in data) || (data.nameBangla is string && data.nameBangla.size() < 200)) &&
             (!('nameEnglish' in data) || (data.nameEnglish is string && data.nameEnglish.size() < 200)) &&
             (!('fatherName' in data) || (data.fatherName is string && data.fatherName.size() < 200)) &&
             (!('motherName' in data) || (data.motherName is string && data.motherName.size() < 200)) &&
             (!('address' in data) || (data.address is string && data.address.size() < 500)) &&
             (!('ocId' in data) || (data.ocId is string && data.ocId.size() < 100)) &&
             (!('signatureURL' in data) || (data.signatureURL is string && data.signatureURL.size() < 1000)) &&
             (!('bloodGroup' in data) || (data.bloodGroup is string && data.bloodGroup.size() < 10)) &&
             (!('nidNo' in data) || (data.nidNo is string && data.nidNo.size() < 50)) &&
             (!('barcode' in data) || (data.barcode is string && data.barcode.size() < 500));
    }
    function isValidMessage(data) {
      return data.chatId is string && data.chatId.size() < 128 &&
             data.senderId is string && data.senderId.size() < 128 &&
             (!('text' in data) || (data.text is string && data.text.size() < 5000)) &&
             (!('mediaUrl' in data) || (data.mediaUrl is string && data.mediaUrl.size() < 1000)) &&
             (!('fileUrl' in data) || (data.fileUrl is string && data.fileUrl.size() < 1000)) &&
             data.type in ['text', 'image', 'video', 'voice', 'file', 'location', 'poll', 'money', 'call'];
    }
    function isValidCall(data) {
      return data.callerId is string && data.receiverId is string &&
             data.type in ['audio', 'video'] &&
             data.status in ['calling', 'ringing', 'connected', 'ended'];
    }
    function isValidStory(data) {
      return data.userId is string && data.userId.size() < 128 &&
             data.videoUrl is string && data.videoUrl.size() < 1000 &&
             (!('caption' in data) || (data.caption is string && data.caption.size() < 1000)) &&
             data.likes is list &&
             data.views is number &&
             (!('comments' in data) || data.comments is list);
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isOwner(uid) && isValidUser(request.resource.data) && 
                      (!('role' in request.resource.data) || request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();

      match /private/identity {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid) && isValidIdentity(request.resource.data);
      }
    }

    match /user_sessions/{sessionId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    match /stories/{storyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId && isValidStory(request.resource.data);
      allow update: if isAuthenticated() && (
        (request.auth.uid == resource.data.userId && isValidStory(request.resource.data)) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'views', 'comments']) &&
         request.resource.data.userId == resource.data.userId &&
         request.resource.data.videoUrl == resource.data.videoUrl)
      );
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() && request.auth.uid == request.resource.data.senderId && isValidMessage(request.resource.data);
        allow update: if isAuthenticated() && request.auth.uid == resource.data.senderId;
        allow delete: if isAuthenticated() && request.auth.uid == resource.data.senderId;
      }
    }

    match /matches/{matchId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.uids;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.uids;
      allow delete: if isAuthenticated() && request.auth.uid in resource.data.uids;
    }

    match /swipes/{swipeId} {
      allow read: if isOwner(resource.data.fromUid);
      allow create: if isOwner(request.resource.data.fromUid);
    }

    match /calls/{callId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.callerId || request.auth.uid == resource.data.receiverId);
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.callerId && isValidCall(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.callerId || request.auth.uid == resource.data.receiverId) && isValidCall(request.resource.data);
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.callerId || request.auth.uid == resource.data.receiverId);
    }
  }
}
